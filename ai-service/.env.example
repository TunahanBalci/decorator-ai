# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=ai-service
API_HOST=0.0.0.0
API_PORT=8000
MOCK_AI=false
# JSON list. Keep "*" for local Flutter/web development.
CORS_ALLOW_ORIGINS=["*"]

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/furniture_ai
POSTGRES_DB=furniture_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Redis (task queue) ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Qdrant (vector DB) ──────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PRODUCTS=furniture_products
# Text vector from text-embedding-005 (semantic search)
QDRANT_TEXT_VECTOR_SIZE=768
# Image vector from multimodalembedding@001 (visual similarity)
QDRANT_IMAGE_VECTOR_SIZE=1408

# ── Vertex AI ────────────────────────────────────────────────
# Your Google Cloud project ID (required for AI features).
VERTEX_PROJECT_ID=your-gcp-project-id
# Flash model — used for lightweight tasks.
VERTEX_MODEL_ID=gemini-3-flash-preview
# Pro model — used for heavy reasoning (room analysis, design strategy, placement).
VERTEX_PRO_MODEL_ID=gemini-3.1-pro-preview
VERTEX_LOCATION=global
# Text embedding model (768-dim vectors)
VERTEX_EMBEDDING_MODEL=text-embedding-005
# Multimodal embedding model (1408-dim vectors, text + image)
VERTEX_MULTIMODAL_MODEL=multimodalembedding@001
# Multimodal model requires a specific region (not global)
VERTEX_MULTIMODAL_LOCATION=us-central1

# ── Image storage ────────────────────────────────────────────
LOCAL_IMAGE_ROOT=/data/images
PRODUCT_IMAGE_DIR=/data/images/products
# Local crawler image root used by product indexing. Docker Compose mounts ../data here.
PRODUCT_EMBEDDING_IMAGE_ROOT=/data/pipeline/output/images
ROOM_UPLOAD_DIR=/data/images/rooms
GENERATED_IMAGE_DIR=/data/images/generated

# ── Limits ───────────────────────────────────────────────────
MAX_UPLOAD_MB=15
DEBUG_PLACEMENT=false
ENABLE_IMAGE_GENERATION=false
DEFAULT_DESIGN_COUNT=3
MAX_CANDIDATES_PER_ITEM=50
MAX_SELECTED_PER_DESIGN=8
IGNORE_EXISTING_FURNITURE=true
REMOVE_EXISTING_FURNITURE=false

# ── Google ADC ───────────────────────────────────────────────
# Path inside the container where the service account key is mounted.
# Mount your key file to ./secrets/gcp-service-account.json on the host.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-service-account.json
